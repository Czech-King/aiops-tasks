**/*.tfstate.backup
**/.terraform.lock.hcl
**/*.tfvars
**/*.tfvars.json
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.venv/
**/venv/
**/.DS_Store
